{
  "name": "kbank-poc",
  "version": "2.0.0",
  "description": "K-Bank: Consumer DeFi Funding Platform on Flow - Cloudflare Workers",
  "main": "src/worker.js",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "dev": "wrangler dev --local",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "docker:build": "docker build -t kbank-poc:latest .",
    "docker:run": "docker run -d --name kbank-bot -p 3000:3000 -p 3001:3001 kbank-poc:latest",
    "worker:build": "node build.mjs"
  },
  "dependencies": {
    "@onflow/fcl": "^1.10.0",
    "telegraf": "^4.15.2",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "esbuild": "^0.20.0",
    "wrangler": "^3.28.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "defi",
    "flow-blockchain",
    "telegram-bot",
    "dao",
    "insurance",
    "k-bank"
  ],
  "author": "K-Bank Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/kbank-poc.git"
  }
}
